rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    // ── users/{userId} ───────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && isValidString(request.resource.data.name, 100)
        && isValidString(request.resource.data.email, 200);
      allow update: if isOwner(userId)
        && request.resource.data.id == userId;
      allow delete: if false;

      match /notes/{noteId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && isValidString(request.resource.data.content, 10000);
        allow update: if isOwner(userId)
          && isValidString(request.resource.data.content, 10000);
        allow delete: if isOwner(userId);

        match /files/{fileId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId)
            && isValidString(request.resource.data.name, 255)
            && isValidString(request.resource.data.url, 2000)
            && isValidString(request.resource.data.storagePath, 2000)
            && request.resource.data.size is number
            && request.resource.data.size > 0
            && request.resource.data.size <= 52428800;
          allow delete: if isOwner(userId);
          allow update: if false;
        }
      }
    }

    // ── usage/{userId_date} ──────────────────────────────────────  ← NOUVEAU
    match /usage/{recordId} {
      allow read: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.count is number
        && request.resource.data.count >= 0;
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ── summaries ────────────────────────────────────────────────
    match /summaries/{summaryId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && isValidString(request.resource.data.originalText, 50000)
        && isValidString(request.resource.data.summary, 50000);
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── quizzes ──────────────────────────────────────────────────
    match /quizzes/{quizId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.questions is list
        && request.resource.data.questions.size() > 0
        && request.resource.data.questions.size() <= 50;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── plans ────────────────────────────────────────────────────
    match /plans/{planId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && isValidString(request.resource.data.plan, 50000)
        && request.resource.data.subjects is list;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── explanations ─────────────────────────────────────────────
    match /explanations/{explanationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && isValidString(request.resource.data.text, 50000)
        && isValidString(request.resource.data.explanation, 50000);
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── solutions ────────────────────────────────────────────────
    match /solutions/{solutionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && isValidString(request.resource.data.exercise, 50000)
        && isValidString(request.resource.data.solution, 50000);
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── flashcards ───────────────────────────────────────────────
    match /flashcards/{flashcardId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.cards is list
        && request.resource.data.cards.size() > 0;
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    // ── chatSessions ─────────────────────────────────────────────
    match /chatSessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId)
        && isValidString(request.resource.data.subject, 100);
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}